# ============================================================
# Central Gas Agent — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=centralgas
POSTGRES_USER=centralgas
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- MQTT (Mosquitto) ---
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-5-20250514

# --- Odoo 17 ---
ODOO_URL=http://localhost:8069
ODOO_DB=centralgas_erp
ODOO_USER=admin
ODOO_PASSWORD=admin

# --- WhatsApp (Meta Cloud API / Twilio) ---
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
JOSUE_WHATSAPP=whatsapp:+52XXXXXXXXXX
TECNICO_WHATSAPP=whatsapp:+52XXXXXXXXXX

# --- PLC SCADA ---
PLC_STAR_IP=192.168.1.253
PLC_STAR_PORT=102
PLC_STAR_RACK=0
PLC_STAR_SLOT=1
SCADA_READ_INTERVAL_S=30
SCADA_ALARM_INTERVAL_S=5

# --- API Server ---
API_PORT=8000
API_HOST=0.0.0.0
LOG_LEVEL=info

# --- CRE Report ---
CRE_EMAIL=reportediariogn@cre.gob.mx
CRE_SENDER_EMAIL=reportes@centralgas.mx
